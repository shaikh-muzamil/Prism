<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Prism</title>
    <link rel="stylesheet" href="/style.css">
    <script>
        window.va = window.va || function () { (window.vaq = window.vaq || []).push(arguments); };
    </script>
    <script defer src="/_vercel/insights/script.js"></script>
</head>

<body>
    <!-- Deep Dark Raycast Background -->
    <div style="position: fixed; inset: 0; background: #0f0f10; z-index: -1;"></div>

    <main style="min-height: 100vh; display: flex; align-items: center; justify-content: center; padding: 20px;">
        
        <!-- Raycast Modal Container -->
        <div class="raycast-modal">
            
            <!-- Modal Header (Input) -->
            <form id="search-form" class="raycast-header">
                <input type="text" id="search-input" name="q" class="raycast-input" placeholder="Search across your apps..."
                    value="<%= typeof query !== 'undefined' ? query : '' %>" required autocomplete="off" autofocus>
                
                <a href="/account" class="raycast-settings-icon" title="Settings">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="12" cy="12" r="3"></circle>
                        <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"></path>
                    </svg>
                </a>
            </form>

            <!-- Container for purely dynamic Ajax rendering -->
            <div id="results-container" class="raycast-results-window">
                <!-- On load with no query, show recents safely as raycast items -->
                <% if (typeof recents !=='undefined' && recents && recents.length > 0 && !(typeof query !== 'undefined' && query)) { %>
                    <div class="raycast-list-group">Recent Slack Activity</div>
                    <div class="raycast-list">
                        <% recents.forEach((item, index) => { %>
                            <div class="raycast-item <%= index === 0 ? 'raycast-active' : '' %>" data-href="<%= item.permalink %>">
                                <div class="flex items-center gap-3" style="overflow: hidden;">
                                    <img src="https://cdn.simpleicons.org/slack/E01E5A" width="16" height="16">
                                    <div class="raycast-item-title"><strong style="color: #fff;"><%= item.user %>:</strong> <%= item.text %></div>
                                </div>
                                <div class="raycast-item-metadata">
                                    <span class="raycast-pill">#<%= item.channel %></span>
                                </div>
                            </div>
                        <% }) %>
                    </div>
                <% } %>
            </div>
            
            <script>
                // Basic Setup
                const form = document.getElementById('search-form');
                const input = document.getElementById('search-input');
                const resultsContainer = document.getElementById('results-container');
                let currentResults = null;
                let currentAiSummary = null;

                // Focus instantly globally on Cmd+K
                document.addEventListener('keydown', (e) => {
                    if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
                        e.preventDefault();
                        input.focus();
                    }
                });

                // Raycast Arrow Key Navigation
                document.addEventListener('keydown', (e) => {
                    const items = Array.from(document.querySelectorAll('.raycast-item'));
                    if (items.length === 0) return;

                    const activeIndex = items.findIndex(item => item.classList.contains('raycast-active'));
                    
                    if (e.key === 'ArrowDown') {
                        e.preventDefault();
                        if (activeIndex >= 0) items[activeIndex].classList.remove('raycast-active');
                        const nextIndex = (activeIndex + 1) >= items.length ? 0 : (activeIndex + 1);
                        items[nextIndex].classList.add('raycast-active');
                        items[nextIndex].scrollIntoView({ block: 'nearest', behavior: 'smooth' });
                    } else if (e.key === 'ArrowUp') {
                        e.preventDefault();
                        if (activeIndex >= 0) items[activeIndex].classList.remove('raycast-active');
                        const prevIndex = (activeIndex - 1) < 0 ? (items.length - 1) : (activeIndex - 1);
                        items[prevIndex].classList.add('raycast-active');
                        items[prevIndex].scrollIntoView({ block: 'nearest', behavior: 'smooth' });
                    } else if (e.key === 'Enter') {
                        // Prevent form submit if not focused on input directly without an active class
                        // Actually form submission handles standard enter, so we must intercept if an item is active
                        if (document.activeElement !== input || activeIndex >= 0) {
                            e.preventDefault();
                            let target = document.activeElement === input ? items[activeIndex] : items.find(i => i.classList.contains('raycast-active'));
                            if (target && target.dataset.href) {
                                window.open(target.dataset.href, '_blank');
                            } else {
                                // Fallback to submit search if typing
                                if (document.activeElement === input) form.dispatchEvent(new Event('submit'));
                            }
                        }
                    }
                });
                
                // Helper to highlight simple text
                function highlightTerm(text, query) {
                    if (!text) return '';
                    if (!query) return text;
                    const cleanText = text.replace(/</g, '&lt;').replace(/>/g, '&gt;');
                    const terms = query.split(' ').filter(t => t.length > 2);
                    if (terms.length === 0) return cleanText;
                    let result = cleanText;
                    terms.forEach(term => {
                        const regex = new RegExp('(' + term + ')', 'gi');
                        result = result.replace(regex, '<span style="color: #a78bfa;">$1</span>');
                    });
                    return result;
                }

                form.addEventListener('submit', async (e) => {
                    e.preventDefault();
                    // Just submitted via enter on input explicitly
                    const q = input.value.trim();
                    if (!q) return;

                    window.history.pushState({}, '', '/?q=' + encodeURIComponent(q));

                    // Skeletal list loading for Raycast
                    resultsContainer.innerHTML = `
                        <div class="raycast-list" style="padding: 12px;">
                            <div class="raycast-item" style="opacity: 0.5; pointer-events: none;"><div style="height: 12px; width: 60%; background: #2c2c2e; border-radius: 4px;"></div></div>
                            <div class="raycast-item" style="opacity: 0.5; pointer-events: none;"><div style="height: 12px; width: 40%; background: #2c2c2e; border-radius: 4px;"></div></div>
                        </div>
                    `;

                    try {
                        const res = await fetch('/api/search?q=' + encodeURIComponent(q));
                        const data = await res.json();
                        currentResults = data.results;
                        currentAiSummary = data.aiSummary;
                        renderUI(q, 'all');
                    } catch (err) {
                        resultsContainer.innerHTML = '<div style="padding: 24px; text-align: center; color: #ff6b6b;">Search Failed.</div>';
                    }
                });

                function renderUI(queryText, activeTab) {
                    if (!currentResults) return;
                    let html = '';

                    // AI Summary integrated purely at the top of the list
                    if (currentAiSummary) {
                        html += `
                            <div class="raycast-ai-summary">
                                <div class="raycast-ai-header">✨ AI Answer</div>
                                <div class="raycast-ai-text">${currentAiSummary}</div>
                            </div>
                        `;
                    }

                    // Tabs
                    html += `
                        <div class="raycast-tabs">
                            <button type="button" class="raycast-tab ${activeTab === 'all' ? 'active' : ''}" onclick="renderUI('${queryText}', 'all')">All</button>
                            <button type="button" class="raycast-tab ${activeTab === 'slack' ? 'active' : ''}" onclick="renderUI('${queryText}', 'slack')">Slack</button>
                            <button type="button" class="raycast-tab ${activeTab === 'notion' ? 'active' : ''}" onclick="renderUI('${queryText}', 'notion')">Notion</button>
                        </div>
                        <div class="raycast-list">
                    `;

                    let items = [];
                    if (activeTab === 'all' || activeTab === 'slack') (currentResults.slack || []).forEach(i => items.push({ ...i, _type: 'slack' }));
                    if (activeTab === 'all' || activeTab === 'notion') (currentResults.notion || []).forEach(i => items.push({ ...i, _type: 'notion' }));

                    if (items.length === 0) {
                        html += '<div style="padding: 32px; text-align: center; color: #8e8e93; font-size: 0.9rem;">No results found.</div>';
                    } else {
                        items.forEach((item, idx) => {
                            const isFirst = idx === 0 ? 'raycast-active' : '';
                            if (item._type === 'slack') {
                                html += `
                                    <div class="raycast-item ${isFirst}" data-href="${item.permalink}">
                                        <div class="flex items-center gap-3" style="overflow: hidden; max-width: 80%;">
                                            <img src="https://cdn.simpleicons.org/slack/E01E5A" width="16" height="16" style="flex-shrink: 0;">
                                            <div class="raycast-item-title"><strong style="color:#fff;">${item.user}:</strong> ${highlightTerm(item.text, queryText)}</div>
                                        </div>
                                        <div class="raycast-item-metadata">
                                            <span class="raycast-pill">#${item.channel}</span>
                                        </div>
                                    </div>
                                `;
                            } else if (item._type === 'notion') {
                                html += `
                                    <div class="raycast-item ${isFirst}" data-href="${item.url}">
                                        <div class="flex items-center gap-3" style="overflow: hidden; max-width: 80%;">
                                            <img src="https://cdn.simpleicons.org/notion/ffffff" width="16" height="16" style="flex-shrink: 0;">
                                            <div class="raycast-item-title"><span style="margin-right: 4px;">${item.icon || '📄'}</span><strong style="color: #fff;">${highlightTerm(item.title, queryText)}</strong></div>
                                        </div>
                                        <div class="raycast-item-metadata">
                                            <span class="raycast-pill">${item.object}</span>
                                        </div>
                                    </div>
                                `;
                            }
                        });
                    }

                    html += '</div>';
                    resultsContainer.innerHTML = html;
                }
                
                if (input.value.trim() && window.location.pathname === '/') {
                    setTimeout(() => { form.dispatchEvent(new Event('submit')); }, 50);
                }
            </script>
        </div>
    </main>
</body>
</html>
