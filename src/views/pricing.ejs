<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Prism | Pricing</title>
    <link rel="stylesheet" href="/style.css">
    
    <style>
        .pricing-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 2rem;
            max-width: 900px;
            margin: 0 auto;
        }

        .pricing-card {
            background: rgba(30, 41, 59, 0.4);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 20px;
            padding: 2.5rem 2rem;
            position: relative;
            backdrop-filter: blur(20px);
            transition: transform 0.3s ease, border-color 0.3s ease;
            display: flex;
            flex-direction: column;
        }

        .pricing-card:hover {
            transform: translateY(-5px);
        }

        .pricing-card.pro {
            background: linear-gradient(180deg, rgba(30, 41, 59, 0.6) 0%, rgba(15, 23, 42, 0.8) 100%);
            border-color: rgba(139, 92, 246, 0.5);
            box-shadow: 0 10px 40px -10px rgba(139, 92, 246, 0.3);
        }

        .pricing-card.pro::before {
            content: '';
            position: absolute;
            top: 0; left: 0; right: 0; height: 3px;
            background: linear-gradient(90deg, #3b82f6, #ec4899);
            border-radius: 20px 20px 0 0;
        }

        .tier-name {
            font-size: 1.25rem;
            font-weight: 600;
            color: #94a3b8;
            margin-bottom: 0.5rem;
            text-transform: uppercase;
            letter-spacing: 0.05em;
        }

        .pro .tier-name {
            background: linear-gradient(90deg, #a78bfa, #f472b6);
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
        }

        .price {
            font-size: 3.5rem;
            font-weight: 700;
            color: #fff;
            margin-bottom: 1rem;
            font-family: 'Inter', -apple-system, sans-serif;
            display: flex;
            align-items: baseline;
        }

        .price span {
            font-size: 1rem;
            color: #64748b;
            font-weight: 400;
            margin-left: 0.25rem;
        }

        .features-list {
            list-style: none;
            padding: 0;
            margin: 2rem 0;
            flex-grow: 1;
        }

        .features-list li {
            display: flex;
            align-items: center;
            gap: 12px;
            margin-bottom: 1rem;
            color: #cbd5e1;
            font-size: 1.05rem;
        }

        .features-list svg {
            flex-shrink: 0;
            stroke: #10b981;
            width: 20px;
            height: 20px;
        }

        .pricing-btn {
            display: block;
            text-align: center;
            padding: 14px;
            border-radius: 12px;
            font-weight: 600;
            font-size: 1.1rem;
            transition: all 0.2s;
            text-decoration: none;
            margin-top: auto;
        }

        .btn-outline {
            background: transparent;
            border: 2px solid rgba(255, 255, 255, 0.2);
            color: #fff;
        }

        .btn-outline:hover {
            border-color: rgba(255, 255, 255, 0.4);
            background: rgba(255, 255, 255, 0.05);
        }

        .btn-gradient {
            background: linear-gradient(135deg, #3b82f6, #8b5cf6, #ec4899);
            color: white;
            border: none;
        }

        .btn-gradient:hover {
            box-shadow: 0 4px 15px rgba(139, 92, 246, 0.4);
            filter: brightness(1.1);
        }
    </style>
</head>

<body>
    <!-- Background Effects -->
    <div class="bg-glow"></div>
    <div class="bg-glow-2"></div>

    <%- include('partials/header', { user: user }) %>

    <main class="main-content container" style="padding-top: 4rem; padding-bottom: 4rem;">
        <section class="text-center mb-12">
            <h1 class="mb-4 text-gradient">Simple, Transparent Pricing</h1>
            <p class="text-secondary text-center"
                style="font-size: 1.25rem; max-width: 600px; margin-left: auto; margin-right: auto;">
                Skip the enterprise sales calls. Setup in 60 seconds with pricing built for startups.
            </p>
        </section>

        <div class="pricing-grid">
            <!-- Free Tier -->
            <div class="pricing-card">
                <div class="tier-name">Seed</div>
                <div class="price">$0<span>/month</span></div>
                <p style="color: #94a3b8; font-size: 0.95rem;">Perfect for small teams starting out.</p>

                <ul class="features-list">
                    <li>
                        <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
                        Up to 3 Team Members
                    </li>
                    <li>
                        <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
                        2 Connected Apps (Slack + Notion)
                    </li>
                    <li>
                        <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
                        Weekly AI Digest
                    </li>
                    <li>
                        <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
                        30-Day Search History
                    </li>
                </ul>

                <a href="<%= user ? '/' : '/signup' %>" class="pricing-btn btn-outline">
                    <%= user ? 'Your Current Plan' : 'Get Started Free' %>
                </a>
            </div>

            <!-- Pro Tier -->
            <div class="pricing-card pro">
                <div class="tier-name">Growth</div>
                <div class="price">$40<span>/month</span></div>
                <p style="color: #94a3b8; font-size: 0.95rem;">Unify all your company's knowledge.</p>

                <ul class="features-list">
                    <li>
                        <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
                        Up to 10 Team Members
                    </li>
                    <li>
                        <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
                        3 Connected Apps (+ Google Workspace)
                    </li>
                    <li>
                        <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
                        Advanced Weekly AI Digest
                    </li>
                    <li>
                        <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
                        90-120 Days Advanced Search History
                    </li>
                </ul>

                <a href="<%= user ? '#' : '/signup' %>" class="pricing-btn btn-gradient">
                    <%= user ? 'Upgrade to Growth' : 'Start Growth Trial' %>
                </a>
            </div>
        </div>

        <div style="text-align: center; margin-top: 4rem; color: #64748b; font-size: 0.95rem;">
            Need more than 10 seats? <a href="mailto:founders@prism-search.com" style="color: #a78bfa; text-decoration: none;">Reach out for an enterprise plan</a>.
        </div>
    </main>
</body>

</html>
